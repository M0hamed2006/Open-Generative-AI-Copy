"scripts": {
  "dev": "next dev",

  "build": "next build",
  "vercel-build": "npm run setup && next build",

  "setup": "npm install --legacy-peer-deps && npm run build:packages",

  "build:packages": "npm run build:workflow && npm run build:agent && npm run build:design && npm run build:studio",

  "build:studio": "npm run build -w studio",
  "build:workflow": "npm run build -w workflow-builder",
  "build:agent": "npm run build -w ai-agent",
  "build:design": "cd packages/Open-AI-Design-Agent/packages/design-agent && npm install && npm run build",

  "postinstall": "npm run setup"
}
